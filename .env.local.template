# ============================================
# Supabase 연결 정보
# ============================================
# 아래 값들을 Supabase 대시보드에서 복사해서 붙여넣으세요
# Settings → API 메뉴에서 확인 가능

# Project URL (예: https://bukkctgeqaedacbugujm.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=여기에_Project_URL_붙여넣기

# anon public key (공개 키 - 클라이언트에서 사용)
NEXT_PUBLIC_SUPABASE_ANON_KEY=여기에_anon_key_붙여넣기

# service_role key (관리자 키 - 서버에서만 사용, 절대 공개 금지!)
SUPABASE_SERVICE_ROLE_KEY=여기에_service_role_key_붙여넣기

# Database 연결 문자열 (Settings → Database → Connection string)
# 형식: postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres
DATABASE_URL=여기에_Database_URL_붙여넣기

# ============================================
# OpenAI API (나중에 추가)
# ============================================
OPENAI_API_KEY=나중에_추가

# ============================================
# Resend (이메일 발송 - 나중에 추가)
# ============================================
RESEND_API_KEY=나중에_추가

# ============================================
# Upstash Redis (나중에 추가)
# ============================================
UPSTASH_REDIS_REST_URL=나중에_추가
UPSTASH_REDIS_REST_TOKEN=나중에_추가


# ============================================
# 작성 방법:
# ============================================
# 1. 이 파일을 .env.local 로 저장하세요
# 2. Supabase 대시보드에서 값 복사
# 3. "여기에_XXX_붙여넣기" 부분을 실제 값으로 교체
# 4. 저장!
#
# ⚠️ 주의: .env.local 파일은 절대 GitHub에 올리지 마세요!
